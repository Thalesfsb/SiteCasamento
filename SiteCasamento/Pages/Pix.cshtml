@page "{id:int}"
@model PixModel
@{
    ViewData["Title"] = "Presentear via PIX";
}

<div class="container mt-5" style="max-width: 720px;">

    <!-- VOLTAR -->
    <a href="/Presentes" class="btn btn-link px-0 mb-3">
        <i class="bi bi-arrow-left"></i> Voltar para a lista de presentes
    </a>

    <div class="card shadow-sm border-0">
        <div class="card-body text-center">

            <h3 class="title-serif mb-2">
                Presentear via PIX 💚
            </h3>

            <p class="text-muted mb-2">
                Presente: <strong>@Model.Presente.Nome</strong>
            </p>

            <p class="fw-bold mb-4">
                Valor sugerido: R$ @Model.Presente.Valor.ToString("N2")
            </p>

            <img src="data:image/png;base64,@Model.QrCodeBase64"
                 class="img-fluid mb-4"
                 style="max-width: 260px;" />

            <p class="text-muted small">
                Escaneie o QR Code acima no aplicativo do seu banco.
            </p>

            <div class="alert alert-success mt-4">
                Após o pagamento, o presente será
                <strong>confirmado manualmente pelo casal</strong>.
            </div>

            <a href="/Presentes" class="btn btn-outline-primary mt-3">
                Voltar para a lista
            </a>
        </div>
    </div>
</div>