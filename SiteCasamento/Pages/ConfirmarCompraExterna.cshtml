@page
@model ConfirmarCompraExternaModel

<div class="container mt-5" style="max-width: 720px;">
    <h2 class="title-serif mb-3">Confirmar compra pelo site</h2>

    <p class="text-muted mb-4">
        Presente: <strong>@Model.Presente?.Nome</strong>
    </p>

    @if (Model.Enviado)
    {
        <div class="alert alert-success">
            Obrigado! Recebemos sua confirmação 💚<br />
            O casal irá validar o recebimento do presente.
        </div>

        <a href="/Presentes" class="btn btn-link px-0 mt-3">
            <i class="bi bi-arrow-left"></i> Voltar para a lista de presentes
        </a>
    }
    else
    {
        @if (!string.IsNullOrEmpty(Model.Erro))
        {
            <div class="alert alert-warning">
                @Model.Erro
            </div>
        }

        <form method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label">Seu nome</label>
                <input class="form-control" asp-for="Nome" />
            </div>

            <div class="mb-3">
                <label class="form-label">Loja (opcional)</label>
                <input class="form-control" asp-for="Loja" />
            </div>

            <div class="mb-3">
                <label class="form-label">Número do pedido (opcional)</label>
                <input class="form-control" asp-for="NumeroPedido" />
            </div>

            <div class="mb-3">
                <label class="form-label">Mensagem (opcional)</label>
                <textarea class="form-control" asp-for="Mensagem" rows="3"></textarea>
            </div>

            <button class="btn btn-primary w-100">
                ✅ Confirmar compra
            </button>
        </form>
    }
</div>