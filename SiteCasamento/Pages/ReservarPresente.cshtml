@page
@model ReservarPresenteModel
@using SiteCasamento.Models

@{
    ViewData["Title"] = "Presentear";
}

<div class="container mt-5" style="max-width: 720px;">

    <!-- VOLTAR -->
    <a href="/Presentes" class="btn btn-link px-0 mb-3">
        <i class="bi bi-arrow-left"></i> Voltar para a lista de presentes
    </a>

    <div class="card shadow-sm border-0">
        <div class="card-body text-center">

            <h3 class="title-serif mb-2">
                @Model.Presente?.Nome
            </h3>

            @if (!string.IsNullOrWhiteSpace(Model.Presente?.Descricao))
            {
                <p class="text-muted mb-3">
                    @Model.Presente.Descricao
                </p>
            }

            <p class="fw-bold mb-4">
                Valor sugerido:
                @(Model.Presente?.Valor > 0
                                ? $"R$ {Model.Presente.Valor:N2}"
                                : "Valor a definir")
            </p>

            @if (!string.IsNullOrEmpty(Model.MensagemErro))
            {
                <div class="alert alert-warning">
                    @Model.MensagemErro
                </div>
            }

            @if (Model.Sucesso)
            {
                <div class="alert alert-success">
                    Presente reservado com sucesso ❤️<br />
                    Obrigado, <strong>@Model.NomeConvidado</strong>.
                </div>

                <div class="alert alert-light text-center mb-5">
                    <strong>📦 Endereço para entrega dos presentes:</strong><br />
                    Rua Síria, 166, ap 31<br />
                    Parque São Jorge – São Paulo/SP<br />
                    CEP 03086-040
                </div>

                <p class="text-muted mb-4">
                    Agora escolha como deseja comprar o presente:
                </p>

                <div class="d-grid gap-2">

                    @* COMPRA EXTERNA (AÇÃO SECUNDÁRIA) *@
                    @if (!string.IsNullOrWhiteSpace(Model.Presente!.LinkCompra))
                    {
                        <a href="@Model.Presente.LinkCompra"
                           target="_blank"
                           rel="noopener"
                           class="btn btn-outline-success btn-secondary-action">
                            🛒 Comprar pelo site
                        </a>

                        <a href="/ConfirmarCompraExterna?id=@Model.Presente.Id"
                           class="btn btn-outline-success btn-secondary-action">
                            ✅ Já comprei pelo site
                        </a>
                    }

                    @* PIX – AÇÃO PRINCIPAL *@
                    <a href="/Pix/@Model.Presente!.Id"
                       class="btn btn-success btn-primary-action mt-1">
                        💚 Presentear via PIX
                    </a>

                </div>
            }
            else
            {
                <form method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-4 text-start">
                        <label class="form-label">Seu nome</label>
                        <input class="form-control"
                               asp-for="NomeConvidado"
                               placeholder="Ex: Maria Silva" />
                    </div>

                    <button class="btn btn-primary btn-lg w-100">
                        Confirmar reserva
                    </button>
                </form>
            }
        </div>
    </div>
</div>