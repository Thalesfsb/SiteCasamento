@page
@model SiteCasamento.Pages.Admin.LoginModel
@{
    ViewData["Title"] = "Login Admin";
}

<div class="container mt-5" style="max-width: 420px;">
    <h3 class="title-serif text-center mb-4">Área Administrativa</h3>

    @if (!string.IsNullOrEmpty(Model.Erro))
    {
        <div class="alert alert-danger text-center">
            @Model.Erro
        </div>
    }

    <form method="post">
        <div class="mb-3">
            <label class="form-label">Senha</label>
            <input type="password"
                   class="form-control"
                   asp-for="Senha"
                   required />
        </div>

        <button class="btn btn-primary w-100">
            Entrar
        </button>
    </form>
</div>