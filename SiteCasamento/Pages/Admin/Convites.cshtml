@page
@model SiteCasamento.Pages.Admin.ConvitesModel
@{
    ViewData["Title"] = "Admin - Convites";
}

<div class="container mt-5">

    <a asp-page="/Admin/Dashboard"
       class="btn btn-link px-0 mb-4">
        <i class="bi bi-arrow-left"></i> Voltar para o Dashboard
    </a>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="fw-bold">Convites</h3>
        <a class="btn btn-success" asp-page="/Admin/ConviteCreate">Novo convite</a>
    </div>

    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Convite</th>
                    <th>Telefone (4 dígitos)</th>
                    <th>Pessoas</th>
                    <th>Última resposta</th>
                    <th class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model.Convites)
                {
                    <tr>
                        <td class="fw-semibold">@c.NomeExibicao</td>
                        <td>@c.TelefoneUltimos4</td>
                        <td>@(c.Pessoas?.Count ?? 0)</td>
                        <td>@(c.DataUltimaResposta?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary"
                               asp-page="/Admin/ConviteEdit" asp-route-id="@c.Id">Editar</a>

                            <a class="btn btn-sm btn-outline-secondary"
                               asp-page="/Admin/ConvitePessoas" asp-route-id="@c.Id">Pessoas</a>

                            <a class="btn btn-sm btn-outline-danger"
                               asp-page="/Admin/ConviteDelete" asp-route-id="@c.Id">Excluir</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
   
</div>