@page
@model SiteCasamento.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Admin - Dashboard";
}

<div class="container mt-5">

    <!-- CABEÇALHO -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold mb-0">Dashboard</h3>
        <a class="btn btn-outline-secondary" asp-page="/Admin/Logout">
            Sair
        </a>
    </div>

    <!-- AÇÕES PENDENTES -->
    <div class="row g-3 mb-4">

        <!-- PAGAMENTOS -->
        <div class="col-md-4">
            <a asp-page="/Admin/PagamentosPix"
               class="card shadow-sm border-0 text-decoration-none h-100">
                <div class="card-body">
                    <div class="fw-bold @(Model.PagamentosPendentes > 0 ? "text-danger" : "text-muted")">
                        Pagamentos pendentes
                    </div>
                    <div class="display-6">
                        @Model.PagamentosPendentes
                    </div>
                    <div class="text-muted">
                        Aguardando confirmação
                    </div>
                </div>
            </a>
        </div>

        <!-- RSVP -->
        <div class="col-md-4">
            <a asp-page="/Admin/RSVP"
               asp-route-filtro="pendente"
               class="card shadow-sm border-0 text-decoration-none h-100">
                <div class="card-body">
                    <div class="fw-bold text-warning">
                        RSVP pendentes
                    </div>
                    <div class="display-6">
                        @Model.TotalPendentes
                    </div>
                    <div class="text-muted">
                        Convidados sem resposta
                    </div>
                </div>
            </a>
        </div>

        <!-- PRESENTES -->
        <div class="col-md-4">
            <a asp-page="/Admin/Presentes"
               asp-route-status="Reservado"
               class="card shadow-sm border-0 text-decoration-none h-100">
                <div class="card-body">
                    <div class="fw-bold text-warning">
                        Presentes reservados
                    </div>
                    <div class="display-6">
                        @Model.PresentesReservados
                    </div>
                    <div class="text-muted">
                        Ainda não pagos
                    </div>
                </div>
            </a>
        </div>

    </div>

    <!-- RESUMO GERAL -->
    <div class="row g-3 mb-4">

        <div class="col-md-4">
            <a asp-page="/Admin/Convites"
               class="card shadow-sm border-0 text-decoration-none text-dark h-100">
                <div class="card-body">
                    <div class="fw-bold">Convites</div>
                    <div class="display-6">@Model.TotalConvites</div>
                    <div class="text-muted">
                        Respondidos: @Model.ConvitesRespondidos
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a asp-page="/Admin/Presentes"
               asp-route-status="Presenteado"
               class="card shadow-sm border-0 text-decoration-none text-dark h-100">
                <div class="card-body">
                    <div class="fw-bold">Presentes pagos</div>
                    <div class="display-6">@Model.PresentesPresenteados</div>
                    <div class="text-muted">
                        Já confirmados
                    </div>
                </div>
            </a>
        </div>

    </div>

    <!-- AÇÕES PRINCIPAIS (PADRÃO) -->
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-primary" asp-page="/Admin/PagamentosPix">
            Pagamentos
        </a>
        <a class="btn btn-outline-primary" asp-page="/Admin/Presentes">
            Presentes
        </a>
        <a class="btn btn-outline-primary" asp-page="/Admin/RSVP">
            RSVP
        </a>
        <a class="btn btn-outline-secondary" asp-page="/Admin/Convites">
            Convites
        </a>
    </div>

</div>