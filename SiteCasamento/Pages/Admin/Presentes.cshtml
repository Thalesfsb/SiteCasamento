@page
@model SiteCasamento.Pages.Admin.PresentesModel
@using SiteCasamento.Models

@{
    ViewData["Title"] = "Admin - Presentes";
}

<div class="container mt-5">

    <!-- VOLTAR -->
    <a asp-page="/Admin/Dashboard"
       class="btn btn-link px-0 mb-3">
        <i class="bi bi-arrow-left"></i> Voltar para o Dashboard
    </a>

    <!-- CABEÇALHO -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold mb-0">Presentes</h3>

        <a asp-page="/Admin/PresenteCreate"
           class="btn btn-primary">
            <i class="bi bi-plus"></i> Novo presente
        </a>
    </div>

    <!-- FILTROS -->
    <div class="mb-3">
        <a asp-page="./Presentes"
           class="btn btn-sm btn-outline-secondary @(Model.Status == null ? "active" : "")">
            Todos
        </a>

        <a asp-page="./Presentes"
           asp-route-status="Disponivel"
           class="btn btn-sm btn-outline-secondary @(Model.Status == StatusPresente.Disponivel ? "active" : "")">
            Disponíveis
        </a>

        <a asp-page="./Presentes"
           asp-route-status="Reservado"
           class="btn btn-sm btn-outline-secondary @(Model.Status == StatusPresente.Reservado ? "active" : "")">
            Reservados
        </a>

        <a asp-page="./Presentes"
           asp-route-status="Presenteado"
           class="btn btn-sm btn-outline-secondary @(Model.Status == StatusPresente.Presenteado ? "active" : "")">
            Presenteados
        </a>
    </div>

    <!-- TABELA -->
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">

            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Nome</th>
                        <th>Valor</th>
                        <th>Status</th>
                        <th>Reservado por</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var p in Model.Itens)
                    {
                        <tr>
                            <td><strong>@p.Nome</strong></td>
                            <td>R$ @p.Valor.ToString("N2")</td>

                            <td>
                                @switch (p.Status)
                                {
                                    case StatusPresente.Disponivel:
                                        <span class="badge bg-success">Disponível</span>
                                        break;
                                    case StatusPresente.Reservado:
                                        <span class="badge bg-warning text-dark">Reservado</span>
                                        break;
                                    case StatusPresente.Presenteado:
                                        <span class="badge bg-primary">Presenteado</span>
                                        break;
                                }
                            </td>

                            <td>
                                @if (!string.IsNullOrEmpty(p.ReservadoPor))
                                {
                                    @p.ReservadoPor
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>

                            <td class="text-end">
                                <a asp-page="/Admin/PresenteEdit"
                                   asp-route-id="@p.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    Editar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>

</div>