@page
@model SiteCasamento.Pages.Admin.PresenteEditModel
@using SiteCasamento.Models

@{
    ViewData["Title"] = "Editar Presente";
}

<div class="container mt-5" style="max-width:720px;">

    <h3 class="fw-bold mb-3">Editar Presente</h3>

    <!-- ✅ MENSAGEM GERAL -->
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            <ul class="mb-0">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <form method="post" class="mt-3">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="Presente.Id" />

        <div class="mb-3">
            <label class="form-label">Nome</label>
            <input class="form-control" asp-for="Presente.Nome" />
            <span class="text-danger" asp-validation-for="Presente.Nome"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Descrição</label>
            <textarea class="form-control" asp-for="Presente.Descricao"></textarea>
            <span class="text-danger" asp-validation-for="Presente.Descricao"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Imagem URL</label>
            <input class="form-control" asp-for="Presente.ImagemUrl" />
            <span class="text-danger" asp-validation-for="Presente.ImagemUrl"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Valor</label>
            <input class="form-control"
                   asp-for="Presente.Valor"
                   type="text" />
            <span class="text-danger" asp-validation-for="Presente.Valor"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Status</label>
            <select class="form-select"
                    asp-for="Presente.Status"
                    asp-items="Html.GetEnumSelectList<StatusPresente>()">
            </select>
            <span class="text-danger" asp-validation-for="Presente.Status"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Link de compra</label>
            <input class="form-control"
                   asp-for="Presente.LinkCompra"
                   placeholder="https://..." />
            <span class="text-danger" asp-validation-for="Presente.LinkCompra"></span>
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-primary">Salvar</button>
            <a class="btn btn-outline-secondary" asp-page="/Admin/Presentes">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}