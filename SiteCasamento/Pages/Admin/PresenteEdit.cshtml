@page
@model SiteCasamento.Pages.Admin.PresenteEditModel
@using SiteCasamento.Models
@{
    ViewData["Title"] = "Editar Presente";
}

<div class="container mt-5" style="max-width:720px;">
    <h3 class="fw-bold">Editar Presente</h3>

    <form method="post" class="mt-3">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="Presente.Id" />

        <div class="mb-3">
            <label class="form-label">Nome</label>
            <input class="form-control" asp-for="Presente.Nome" required />
        </div>

        <div class="mb-3">
            <label class="form-label">Descrição</label>
            <textarea class="form-control" asp-for="Presente.Descricao"></textarea>
        </div>

        <div class="mb-3">
            <label class="form-label">Imagem URL</label>
            <input class="form-control" asp-for="Presente.ImagemUrl" />
        </div>

        <div class="mb-3">
            <label class="form-label">Valor</label>
            <input class="form-control" asp-for="Presente.Valor" type="number" step="0.01" min="0" />
        </div>

        <div class="mb-3">
            <label class="form-label">Status</label>
            <select class="form-select" asp-for="Presente.Status">
                <option value="@StatusPresente.Disponivel">Disponível</option>
                <option value="@StatusPresente.Reservado">Reservado</option>
                <option value="@StatusPresente.Presenteado">Presenteado</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Link de compra</label>
            <input class="form-control" asp-for="Presente.LinkCompra" placeholder="https://..." />
        </div>

        <button class="btn btn-primary">Salvar</button>
        <a class="btn btn-outline-secondary" asp-page="/Admin/Presentes">Cancelar</a>

    </form>
</div>