@page
@model SiteCasamento.Pages.Admin.ConfirmadosModel
@{
    ViewData["Title"] = "Admin - Confirmados";
}

<div class="container mt-5">

    <a asp-page="/Admin/Dashboard"
       class="btn btn-link px-0 mb-4">
        <i class="bi bi-arrow-left"></i> Voltar para o Dashboard
    </a>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="fw-bold mb-0">Lista de Confirmados</h3>
    </div>

    <p class="text-muted">
        Total confirmados: <strong>@Model.Itens.Count</strong>
    </p>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Convite</th>
                    <th>Data da resposta</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Itens.Any())
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted py-4">
                            Ainda não há confirmações.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var x in Model.Itens)
                    {
                        <tr>
                            <td class="fw-semibold">@x.Nome</td>
                            <td>@x.Convite</td>
                            <td>@(x.DataResposta?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>