@page
@model SiteCasamento.Pages.Admin.ConviteCreateModel
@{
    ViewData["Title"] = "Novo Convite";
}

<div class="container mt-5" style="max-width:720px;">
    <h3 class="fw-bold">Novo Convite</h3>

    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <form method="post" class="card p-4 shadow-sm border-0">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label class="form-label">Nome do convite</label>
            <input class="form-control" asp-for="Convite.NomeExibicao" placeholder="Ex: Tio Fábio e Família" />
        </div>

        <div class="mb-3">
            <label class="form-label">Últimos 4 dígitos do telefone</label>
            <input class="form-control" asp-for="Convite.TelefoneUltimos4" maxlength="4" placeholder="Ex: 1234" />
        </div>


        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">
                Salvar
            </button>

            <a asp-page="/Admin/Convites"
               class="btn btn-outline-secondary">
                Cancelar
            </a>
        </div>

    </form>
</div>