@page
@model SiteCasamento.Pages.Admin.PagamentosPixModel
@using SiteCasamento.Models

@{
    ViewData["Title"] = "Admin - Pagamentos";
}

<div class="container mt-5">

    <!-- VOLTAR -->
    <a asp-page="/Admin/Dashboard"
       class="btn btn-link px-0 mb-3">
        <i class="bi bi-arrow-left"></i> Voltar para o Dashboard
    </a>

    <!-- CABEÇALHO -->
    <div class="mb-4">
        <h3>Pagamentos pendentes</h3>
        <p>PIX e compras externas aguardando confirmação</p>
    </div>

    @if (!Model.Pendentes.Any())
    {
        <div class="alert alert-info">
            Nenhum pagamento pendente no momento.
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">

                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Presente</th>
                            <th>Convidado</th>
                            <th>Tipo</th>
                            <th>Valor</th>
                            <th>Data</th>
                            <th class="text-end">Ações</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var p in Model.Pendentes)
                        {
                            <tr>
                                <!-- PRESENTE -->
                                <td style="max-width:320px;">
                                    <div class="fw-semibold text-truncate" title="@p.PresenteNome">
                                        @p.PresenteNome
                                    </div>
                                </td>

                                <!-- CONVIDADO -->
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(p.NomeConvidado))
                                    {
                                        @p.NomeConvidado
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>

                                <!-- TIPO -->
                                <td>
                                    @if (p.Tipo == TipoPagamento.Pix)
                                    {
                                        <span class="badge bg-success">PIX</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary">Compra externa</span>
                                    }
                                </td>

                                <!-- VALOR -->
                                <td class="text-nowrap">
                                    <strong>R$ @p.Valor.ToString("N2")</strong>
                                </td>

                                <!-- DATA -->
                                <td class="text-nowrap">
                                    @p.DataCriacao.ToString("dd/MM/yyyy HH:mm")
                                </td>

                                <!-- AÇÕES -->
                                <td>
                                    <div class="d-flex justify-content-end gap-1">
                                        <form method="post"
                                              asp-page-handler="Confirmar"
                                              asp-route-id="@p.Id">
                                            @Html.AntiForgeryToken()
                                            <button class="btn btn-success btn-sm">
                                                Confirmar
                                            </button>
                                        </form>

                                        <form method="post"
                                              asp-page-handler="Recusar"
                                              asp-route-id="@p.Id">
                                            @Html.AntiForgeryToken()
                                            <button class="btn btn-outline-danger btn-sm">
                                                Recusar
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>

                            <!-- DETALHES DA COMPRA EXTERNA -->
                            @if (p.Tipo == TipoPagamento.CompraExterna &&
                                                (!string.IsNullOrEmpty(p.Loja) ||
                                                !string.IsNullOrEmpty(p.NumeroPedido) ||
                                                !string.IsNullOrEmpty(p.Mensagem)))
                            {
                                <tr class="table-light">
                                    <td colspan="6">
                                        <div class="small text-muted">

                                            @if (!string.IsNullOrEmpty(p.Loja))
                                            {
                                                <div><strong>Loja:</strong> @p.Loja</div>
                                            }

                                            @if (!string.IsNullOrEmpty(p.NumeroPedido))
                                            {
                                                <div><strong>Pedido:</strong> @p.NumeroPedido</div>
                                            }

                                            @if (!string.IsNullOrEmpty(p.Mensagem))
                                            {
                                                <div><strong>Mensagem:</strong> @p.Mensagem</div>
                                            }

                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                    
                </table>

            </div>
        </div>
    }

</div>
