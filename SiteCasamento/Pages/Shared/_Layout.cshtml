<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Nosso Casamento</title>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"rel="stylesheet"/>

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet"/>

    <!-- CSS do site -->
    <link rel="stylesheet"href="~/css/site.css"asp-append-version="true" />
</head>

<body class="@(Context.Request.Path.StartsWithSegments("/Admin") ? "admin" : "")">
    <header>
        <nav class="navbar navbar-light bg-transparent mb-4">
            <div class="container">
                <a class="navbar-brand title-serif fs-4" asp-page="/Index">
                    Ana Laura & Júlio
                </a>
            </div>
        </nav>
    </header>

    <main role="main" class="pb-3">
        @RenderBody()
    </main>

    <footer class="mt-5 py-4 text-center text-muted">
        <div class="container">
            &copy; 2026 - Ana Laura & Júlio
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>